# fancy-print — gateway 镜像
#
# 在仓库根目录：
#   docker build -f cloud/deploy/docker/Dockerfile.gateway -t fancy-print-gateway:latest .

FROM node:22-bookworm-slim
WORKDIR /opt/cloud

COPY cloud/package.json cloud/package-lock.json ./
COPY cloud ./

RUN npm ci \
  && npm run build -w @fancy-print/config \
  && npm run build -w gateway

ENV NODE_ENV=production
EXPOSE 3000

CMD ["node", "apps/gateway/dist/index.js"]
