# fancy-print — parent-bff 镜像
#
# 在仓库根目录：
#   docker build -f cloud/deploy/docker/Dockerfile.parent-bff -t fancy-print-parent-bff:latest .

FROM node:22-bookworm-slim
WORKDIR /opt/cloud

COPY cloud/package.json cloud/package-lock.json ./
COPY cloud ./

RUN npm ci \
  && npm run build -w @fancy-print/config \
  && npm run build -w parent-bff

ENV NODE_ENV=production
EXPOSE 3002

CMD ["node", "apps/parent-bff/dist/main.js"]
