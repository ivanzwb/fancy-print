# 复制为 stack.env 后按需修改（deploy.sh 默认读取 cloud/deploy/env/stack.env）
# cp cloud/deploy/env/stack.example.env cloud/deploy/env/stack.env

# ── device-api ─────────────────────────────────────────
DEVICE_JWT_ACCESS_SECRET=change-me-access-secret
DEVICE_JWT_REFRESH_SECRET=change-me-refresh-secret

# BullMQ 单 API 副本并发槽（worker 进程见 docker-compose 内 PIPELINE_WORKER_CONCURRENCY）
PIPELINE_QUEUE_CONCURRENCY=8
PIPELINE_WORKER_CONCURRENCY=16

# ── parent-bff ─────────────────────────────────────────
PARENT_JWT_ACCESS_SECRET=change-me-parent-access
PARENT_JWT_REFRESH_SECRET=change-me-parent-refresh
# 开发桩登录密码（量产请配合 OIDC，见 cloud/README.md）
PARENT_DEV_PASSWORD=dev
